{
  "name": "ReleaseNotification",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "movie",
        "series",
        "comic",
        "event"
      ]
    },
    "release_date": {
      "type": "string",
      "format": "date"
    },
    "description": {
      "type": "string"
    },
    "image_url": {
      "type": "string"
    },
    "is_published": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "title",
    "type",
    "release_date"
  ]
}